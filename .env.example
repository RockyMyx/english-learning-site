# TTS 提供商配置
# 可选值: 'zhipu' (智谱AI) | 'minimax' (MiniMax)
VITE_TTS_PROVIDER=zhipu

# 智谱 AI API Key
# 获取地址: https://open.bigmodel.cn/
VITE_ZHIPU_API_KEY=your_zhipu_api_key_here

# MiniMax API Key
# 获取地址: https://www.minimaxi.com/
# 格式: sk-api-{groupId}-{key}
VITE_MINIMAX_API_KEY=your_minimax_api_key_here
